{
  "rewrites": [
    { "source": "/api/anthropic", "destination": "/api/anthropic" },
    { "source": "/api/gemini/(.*)", "destination": "/api/gemini" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
